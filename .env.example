# Database
DATABASE_URL=postgresql+asyncpg://poms:poms_dev_password@localhost:5432/poms
POSTGRES_DB=poms
POSTGRES_USER=poms
POSTGRES_PASSWORD=poms_dev_password
POSTGRES_PORT=5432

# pgAdmin
PGADMIN_EMAIL=admin@poms.dev
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# Azure OpenAI — Completion 
AZURE_OPENAI_API_KEY=REPLACE_ME
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# Azure OpenAI — Embeddings (text-embedding-3-large)
AZURE_OPENAI_EMBED_API_KEY=REPLACE_ME
AZURE_OPENAI_EMBED_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_EMBED_DIMENSIONS=3072

# Gmail
GMAIL_CREDENTIALS_PATH=./credentials.json
GMAIL_TOKEN_PATH=./token.json
AGENT_EMAIL=po.processing.demo@gmail.com

# Application
POLL_INTERVAL_SECONDS=30
LOG_LEVEL=INFO
LOG_PATH=./logs
DEBUG=true

# Telemetry
AGNO_TELEMETRY=false
